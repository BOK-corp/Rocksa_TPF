# ============================================================
# LOCAL SECRETS template. Copy to a git-ignored .env and fill in:
#
#   cp .env.example .env
#
# Non-secret/shared dev config already lives in the COMMITTED
# .env.development, so a fresh clone runs with working auth without
# this file. You only need a local .env for the secret values below
# (e.g. real server-side Firebase Auth or a non-default DB).
# ============================================================

# ---- Web client (apps/web, Vite VITE_* prefix) -------------------------------
# These are PUBLIC (shipped in the browser bundle). Defaults come from
# .env.development; only override here if you point at a different project.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=rocksatpf
VITE_FIREBASE_APP_ID=
VITE_API_URL=http://localhost:8787

# Optional — Firebase Auth emulator for the web client. Blank = real Firebase.
VITE_FIREBASE_AUTH_EMULATOR=               # e.g. http://localhost:9099

# ---- API server (apps/api) ---------------------------------------------------
PORT=8787
WEB_ORIGIN=http://localhost:5173
DATABASE_URL=postgres://rocksa:rocksa@localhost:5432/rocksa
FIREBASE_PROJECT_ID=rocksatpf

# SECRET. Service-account JSON for server-side token verification.
#   - Real Firebase Auth: paste the service-account JSON inline (single line).
#   - Local Auth emulator: leave blank and set FIREBASE_AUTH_EMULATOR_HOST below;
#     the verifier then skips signature checks.
# NEVER commit a real value here — keep it only in your local .env.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_AUTH_EMULATOR_HOST=               # e.g. localhost:9099
