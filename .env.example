# ============================================================
# Web client (apps/web, picked up by Vite via the VITE_* prefix)
# ============================================================
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=rocksa
VITE_FIREBASE_APP_ID=

# Optional — Firebase Auth emulator. Leave empty for production.
VITE_FIREBASE_AUTH_EMULATOR=                # e.g. http://localhost:9099

# ============================================================
# Data Connect seed script (scripts/seed-dataconnect.ts)
# ============================================================
FIREBASE_PROJECT_ID=rocksa

# Set to point seeds at the local Data Connect emulator instead of prod.
DATACONNECT_EMULATOR=                       # e.g. http://localhost:9399

# Path to a Google service account JSON file for prod seeding. Read by
# google-auth-library via Application Default Credentials.
GOOGLE_APPLICATION_CREDENTIALS=
