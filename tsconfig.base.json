{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "useDefineForClassFields": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["bun"],
    "baseUrl": ".",
    "paths": {
      "@rocksa/ui": ["packages/ui/src/index.ts"],
      "@rocksa/ui/*": ["packages/ui/src/*"],
      "@rocksa/auth": ["packages/auth/src/index.ts"],
      "@rocksa/auth/*": ["packages/auth/src/*"],
      "@rocksa/db": ["packages/db/src/index.ts"],
      "@rocksa/db/*": ["packages/db/src/*"],
      "@rocksa/domain": ["packages/domain/src/index.ts"],
      "@rocksa/domain/*": ["packages/domain/src/*"],
      "@rocksa/cart": ["packages/cart/src/index.ts"],
      "@rocksa/cart/*": ["packages/cart/src/*"]
    }
  }
}
