{
  "name": "rocksa",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "bun --filter @rocksa/web dev",
    "api": "bun --filter @rocksa/api dev",
    "db:generate": "bun --filter @rocksa/db generate",
    "db:migrate": "bun --filter @rocksa/db migrate",
    "db:seed": "bun --filter @rocksa/db seed",
    "build": "bun --filter='@rocksa/*' run build",
    "typecheck": "bun --filter='@rocksa/*' run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint .",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check ."
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "oxlint": "^0.15.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.6"
}
